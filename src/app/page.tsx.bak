"use client";

import { FormEvent, useMemo, useState } from "react";

const WHATSAPP_NUMBER = "966500000000";

const offers = [
  {
    id: "1",
    label: "قطعة واحدة",
    price: "99 ريال",
    note: "تجربة أولى",
  },
  {
    id: "2",
    label: "قطعتين",
    price: "169 ريال",
    note: "الأكثر اختياراً",
  },
  {
    id: "3",
    label: "3 قطع",
    price: "229 ريال",
    note: "للبيت كامل",
  },
];

const videos = [
  {
    title: "الجو يصير مكتوم بعد المكيف؟",
    file: "/videos/01_hook_direct_ksa_ar.mp4",
  },
  {
    title: "تجربة بسيطة داخل الغرفة",
    file: "/videos/02_problem_story_ksa_ar.mp4",
  },
  {
    title: "اطلبه الحين",
    file: "/videos/03_solution_cta_ksa_ar.mp4",
  },
];

export default function Home() {
  const [selectedOffer, setSelectedOffer] = useState("2");
  const [fullName, setFullName] = useState("");
  const [phone, setPhone] = useState("");
  const [city, setCity] = useState("");
  const [district, setDistrict] = useState("");

  const offer = useMemo(
    () => offers.find((item) => item.id === selectedOffer) ?? offers[1],
    [selectedOffer]
  );

  function buildWhatsappMessage() {
    return `السلام عليكم، أريد تأكيد طلب منتج تحسين أجواء الغرفة مع المكيف.

الطلب: ${offer.label}
السعر: ${offer.price}

الاسم: ${fullName}
رقم الجوال: ${phone}
المدينة: ${city}
الحي: ${district}

طريقة الدفع: الدفع عند الاستلام`;
  }

  function handleSubmit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();

    const message = encodeURIComponent(buildWhatsappMessage());
    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${message}`;

    window.open(url, "_blank", "noopener,noreferrer");
  }

  return (
    <main dir="rtl" className="min-h-screen bg-[#f7f2ea] text-[#191613]">
      <section className="mx-auto grid max-w-7xl gap-10 px-5 py-8 lg:grid-cols-2 lg:items-center lg:py-14">
        <div className="order-2 lg:order-1">
          <p className="mb-4 inline-flex rounded-full bg-[#191613] px-4 py-2 text-sm font-semibold text-white">
            الدفع عند الاستلام متاح في السعودية
          </p>

          <h1 className="text-4xl font-black leading-tight sm:text-5xl lg:text-6xl">
            جو الغرفة يصير ألطف بعد تشغيل المكيف
          </h1>

          <p className="mt-5 max-w-2xl text-lg leading-8 text-[#5f574f]">
            حل بسيط يساعدك تحس بانتعاش أكثر داخل الغرفة، خصوصاً بعد تشغيل المكيف
            في غرف النوم، المجالس، أو المكتب المنزلي.
          </p>

          <div className="mt-8 grid gap-3 sm:grid-cols-3">
            {offers.map((item) => (
              <button
                key={item.id}
                type="button"
                onClick={() => setSelectedOffer(item.id)}
                className={`rounded-3xl border p-5 text-right transition ${
                  selectedOffer === item.id
                    ? "border-[#0f766e] bg-[#0f766e] text-white shadow-lg"
                    : "border-[#e0d6c9] bg-white text-[#191613]"
                }`}
              >
                <p className="text-lg font-black">{item.label}</p>
                <p className="mt-2 text-2xl font-black">{item.price}</p>
                <p className="mt-1 text-sm opacity-80">{item.note}</p>
              </button>
            ))}
          </div>

          <a
            href="#order"
            className="mt-8 inline-block rounded-2xl bg-[#0f766e] px-8 py-4 text-center text-lg font-bold text-white shadow-lg transition hover:bg-[#115e59]"
          >
            اطلبه الحين
          </a>

          <p className="mt-4 text-sm text-[#7a7068]">
            بعد تسجيل الطلب، يتم تأكيده عبر واتساب قبل الشحن.
          </p>
        </div>

        <div className="order-1 rounded-[2rem] bg-white p-3 shadow-2xl lg:order-2">
          <video
            className="aspect-[9/16] w-full rounded-[1.5rem] object-cover"
            src="/videos/03_solution_cta_ksa_ar.mp4"
            controls
            playsInline
            preload="metadata"
          />
        </div>
      </section>

      <section className="bg-white px-5 py-12">
        <div className="mx-auto max-w-7xl">
          <h2 className="text-3xl font-black">هل هذا مناسب لك؟</h2>

          <div className="mt-8 grid gap-4 md:grid-cols-4">
            {["غرفة النوم", "غرفة الجلوس", "المكتب المنزلي", "الغرف المغلقة"].map(
              (item) => (
                <div
                  key={item}
                  className="rounded-3xl border border-[#eee5da] bg-[#fffaf2] p-5 text-center font-bold"
                >
                  {item}
                </div>
              )
            )}
          </div>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-5 py-12">
        <div className="grid gap-8 lg:grid-cols-2">
          <div>
            <h2 className="text-3xl font-black">ليش الناس تجرّبه؟</h2>

            <div className="mt-6 space-y-4">
              {[
                "إحساس ألطف داخل الغرفة",
                "تجربة أكثر راحة مع المكيف",
                "سهل الاستخدام",
                "مناسب للاستخدام اليومي",
                "بدون خطوات معقدة",
              ].map((benefit) => (
                <div key={benefit} className="rounded-2xl bg-white p-5 shadow-sm">
                  <p className="font-bold">✓ {benefit}</p>
                </div>
              ))}
            </div>
          </div>

          <div className="rounded-[2rem] bg-[#191613] p-8 text-white">
            <h2 className="text-3xl font-black">طريقة الاستخدام</h2>

            <div className="mt-6 space-y-5">
              {[
                "افتح المنتج",
                "ضعه في المكان المناسب داخل الغرفة",
                "شغّل المكيف",
                "استمتع بجو ألطف",
              ].map((step, index) => (
                <div key={step} className="flex gap-4">
                  <span className="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#0f766e] font-black">
                    {index + 1}
                  </span>
                  <p className="pt-1 text-lg">{step}</p>
                </div>
              ))}
            </div>

            <a
              href="#order"
              className="mt-8 block rounded-2xl bg-white px-8 py-4 text-center text-lg font-bold text-[#191613]"
            >
              اطلبه الحين
            </a>
          </div>
        </div>
      </section>

      <section className="bg-white px-5 py-12">
        <div className="mx-auto max-w-7xl">
          <h2 className="text-3xl font-black">شاهد التجربة</h2>

          <div className="mt-8 grid gap-6 md:grid-cols-3">
            {videos.map((video) => (
              <div key={video.file} className="rounded-[1.5rem] bg-[#f7f2ea] p-3">
                <video
                  className="aspect-[9/16] w-full rounded-[1.2rem] object-cover"
                  src={video.file}
                  controls
                  playsInline
                  preload="metadata"
                />
                <p className="mt-3 text-center font-bold">{video.title}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="order" className="mx-auto max-w-5xl px-5 py-12">
        <div className="grid overflow-hidden rounded-[2rem] bg-white shadow-2xl lg:grid-cols-2">
          <div className="bg-[#0f766e] p-8 text-white">
            <p className="inline-flex rounded-full bg-white px-4 py-2 text-sm font-bold text-[#0f766e]">
              عرض اليوم
            </p>

            <h2 className="mt-6 text-4xl font-black">اطلبه الآن</h2>

            <p className="mt-4 text-lg leading-8 opacity-90">
              اختر الكمية، اكتب بياناتك، وسيتم تحويلك إلى واتساب لتأكيد الطلب.
            </p>

            <div className="mt-8 rounded-3xl bg-white p-6 text-[#191613]">
              <p className="text-sm font-bold text-[#7a7068]">الطلب المختار</p>
              <p className="mt-2 text-3xl font-black">{offer.label}</p>
              <p className="mt-2 text-4xl font-black text-[#0f766e]">
                {offer.price}
              </p>
              <p className="mt-3 text-sm text-[#7a7068]">
                الدفع عند الاستلام — تأكيد الطلب عبر واتساب
              </p>
            </div>
          </div>

          <form onSubmit={handleSubmit} className="space-y-5 p-8">
            <div>
              <label className="mb-2 block font-bold">الكمية</label>
              <select
                value={selectedOffer}
                onChange={(event) => setSelectedOffer(event.target.value)}
                className="w-full rounded-2xl border border-[#e0d6c9] bg-[#fffaf2] px-4 py-4 text-lg outline-none focus:border-[#0f766e]"
              >
                {offers.map((item) => (
                  <option key={item.id} value={item.id}>
                    {item.label} — {item.price}
                  </option>
                ))}
              </select>
            </div>

            <div>
              <label className="mb-2 block font-bold">الاسم الكامل</label>
              <input
                required
                value={fullName}
                onChange={(event) => setFullName(event.target.value)}
                placeholder="مثال: نورة العتيبي"
                className="w-full rounded-2xl border border-[#e0d6c9] bg-[#fffaf2] px-4 py-4 text-lg outline-none focus:border-[#0f766e]"
              />
            </div>

            <div>
              <label className="mb-2 block font-bold">رقم الجوال</label>
              <input
                required
                value={phone}
                onChange={(event) => setPhone(event.target.value)}
                placeholder="05xxxxxxxx"
                className="w-full rounded-2xl border border-[#e0d6c9] bg-[#fffaf2] px-4 py-4 text-lg outline-none focus:border-[#0f766e]"
              />
            </div>

            <div>
              <label className="mb-2 block font-bold">المدينة</label>
              <input
                required
                value={city}
                onChange={(event) => setCity(event.target.value)}
                placeholder="مثال: الرياض"
                className="w-full rounded-2xl border border-[#e0d6c9] bg-[#fffaf2] px-4 py-4 text-lg outline-none focus:border-[#0f766e]"
              />
            </div>

            <div>
              <label className="mb-2 block font-bold">الحي</label>
              <input
                required
                value={district}
                onChange={(event) => setDistrict(event.target.value)}
                placeholder="مثال: النرجس"
                className="w-full rounded-2xl border border-[#e0d6c9] bg-[#fffaf2] px-4 py-4 text-lg outline-none focus:border-[#0f766e]"
              />
            </div>

            <button
              type="submit"
              className="w-full rounded-2xl bg-[#0f766e] px-8 py-5 text-xl font-black text-white shadow-lg transition hover:bg-[#115e59]"
            >
              تأكيد الطلب عبر واتساب
            </button>

            <p className="text-center text-sm text-[#7a7068]">
              لن يتم شحن الطلب قبل تأكيده عبر واتساب.
            </p>
          </form>
        </div>
      </section>

      <section className="mx-auto max-w-5xl px-5 py-12">
        <h2 className="text-3xl font-black">أسئلة شائعة</h2>

        <div className="mt-6 space-y-4">
          <details className="rounded-2xl bg-white p-5 shadow-sm">
            <summary className="cursor-pointer font-black">
              هل المنتج طبي؟
            </summary>
            <p className="mt-3 leading-8 text-[#5f574f]">
              لا. المنتج غير طبي ولا يعالج أي حالة صحية. استخدامه فقط لتحسين
              الإحساس بالراحة والانتعاش داخل الغرفة.
            </p>
          </details>

          <details className="rounded-2xl bg-white p-5 shadow-sm">
            <summary className="cursor-pointer font-black">
              هل يوجد دفع عند الاستلام؟
            </summary>
            <p className="mt-3 leading-8 text-[#5f574f]">
              نعم، الدفع عند الاستلام متاح. يتم تأكيد الطلب أولاً عبر واتساب.
            </p>
          </details>

          <details className="rounded-2xl bg-white p-5 shadow-sm">
            <summary className="cursor-pointer font-black">
              أين يمكن استخدامه؟
            </summary>
            <p className="mt-3 leading-8 text-[#5f574f]">
              يمكن استخدامه في غرفة النوم، المجلس، المكتب المنزلي، أو الغرف
              المغلقة مع المكيف.
            </p>
          </details>
        </div>
      </section>

      <footer className="px-5 pb-10 text-center text-sm leading-7 text-[#7a7068]">
        المنتج غير طبي ولا يقدّم أي ادعاءات علاجية أو صحية. الاستخدام لغرض تحسين
        الإحساس بالراحة والانتعاش داخل الغرفة فقط.
      </footer>
    </main>
  );
}